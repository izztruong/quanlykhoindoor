generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryCounts   InventoryCount[]
  salesOrders       SalesOrder[]
  reorderThresholds ProductReorderThreshold[]
  stockChecks       StockCheck[]
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  createdAt DateTime @default(now())

  stockImports    StockImport[]
  stockExports    StockExport[]
  salesOrders     SalesOrder[]
  inventoryCounts InventoryCount[]
}

model ProductGroup {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  products Product[]
}

model Unit {
  id   String @id @default(cuid())
  code String @unique
  name String

  products          Product[]
  finishedGoodItems FinishedGoodItem[]
}

// Catalog of "đồ thành phẩm" (prepared/finished items and supplies checked
// alongside raw materials in a phiếu kiểm kê) — independent of Product, since
// many of these (cups, straws, lids, brewed liquids) aren't raw-material SKUs.
model FinishedGoodItem {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id])
  createdAt DateTime @default(now())

  stockCheckFinishedItems StockCheckFinishedItem[]
}

model Product {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  unitId         String
  unit           Unit         @relation(fields: [unitId], references: [id])
  productGroupId String
  productGroup   ProductGroup @relation(fields: [productGroupId], references: [id])
  costPrice      Decimal      @default(0) @db.Decimal(18, 2)
  note           String?
  createdAt      DateTime     @default(now())

  stockImportItems    StockImportItem[]
  stockExportItems    StockExportItem[]
  inventoryCountItems InventoryCountItem[]
  salesOrderItems     SalesOrderItem[]
  reorderThresholds   ProductReorderThreshold[]
  stockCheckItems     StockCheckItem[]
  supplierPrices      ProductSupplierPrice[]
}

// Per-supplier price list: the same product can be sourced from more than
// one supplier at different import/export prices. Optional — a product with
// no rows here just falls back to Product.costPrice everywhere.
model ProductSupplierPrice {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  importPrice Decimal  @db.Decimal(18, 2)
  exportPrice Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now())

  @@unique([productId, supplierId])
}

// Per-user reorder thresholds for "Order nhanh": each user has their own
// min/max per product (e.g. different counters/staff restock to different
// levels), so this is scoped by user, not a global Product setting.
model ProductReorderThreshold {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity Decimal  @db.Decimal(18, 3)
  maxQuantity Decimal  @db.Decimal(18, 3)
  createdAt   DateTime @default(now())

  @@unique([userId, productId])
}

model Supplier {
  id      String  @id @default(cuid())
  code    String  @unique
  name    String
  phone   String?
  address String?

  stockImports     StockImport[]
  stockExports     StockExport[]
  productPrices    ProductSupplierPrice[]
  stockExportItems StockExportItem[]
}

model Customer {
  id      String  @id @default(cuid())
  code    String  @unique
  name    String
  phone   String?
  address String?

  stockImports StockImport[]
  stockExports StockExport[]
}

enum StockTransactionStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum StockImportType {
  PURCHASE
  CUSTOMER_RETURN
  TRANSFER_IN
  OTHER
}

enum StockExportType {
  SALE
  SUPPLIER_RETURN
  TRANSFER_OUT
  DAMAGE
  OTHER
}

enum TransactionForm {
  CASH
  BANK_TRANSFER
  DEBT
  OTHER
}

model StockImport {
  id            String                 @id @default(cuid())
  code          String                 @unique
  type          StockImportType        @default(PURCHASE)
  transactionAt DateTime
  form          TransactionForm        @default(CASH)
  status        StockTransactionStatus @default(COMPLETED)
  note          String?
  warehouseId   String
  warehouse     Warehouse              @relation(fields: [warehouseId], references: [id])
  supplierId    String?
  supplier      Supplier?              @relation(fields: [supplierId], references: [id])
  customerId    String?
  customer      Customer?              @relation(fields: [customerId], references: [id])
  createdById   String?
  createdAt     DateTime               @default(now())

  items StockImportItem[]

  @@index([warehouseId, transactionAt])
}

model StockImportItem {
  id            String      @id @default(cuid())
  stockImportId String
  stockImport   StockImport @relation(fields: [stockImportId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Decimal     @db.Decimal(18, 3)
  costPrice     Decimal     @db.Decimal(18, 2)
  costAmount    Decimal     @db.Decimal(18, 2)
  note          String?

  @@index([productId])
}

model StockExport {
  id            String                 @id @default(cuid())
  code          String                 @unique
  type          StockExportType        @default(SALE)
  transactionAt DateTime
  form          TransactionForm        @default(CASH)
  status        StockTransactionStatus @default(COMPLETED)
  note          String?
  warehouseId   String
  warehouse     Warehouse              @relation(fields: [warehouseId], references: [id])
  supplierId    String?
  supplier      Supplier?              @relation(fields: [supplierId], references: [id])
  customerId    String?
  customer      Customer?              @relation(fields: [customerId], references: [id])
  salesOrderId  String?                @unique
  salesOrder    SalesOrder?            @relation(fields: [salesOrderId], references: [id])
  createdById   String?
  createdAt     DateTime               @default(now())

  items StockExportItem[]

  @@index([warehouseId, transactionAt])
}

model StockExportItem {
  id            String      @id @default(cuid())
  stockExportId String
  stockExport   StockExport @relation(fields: [stockExportId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Decimal     @db.Decimal(18, 3)
  costPrice     Decimal     @db.Decimal(18, 2)
  costAmount    Decimal     @db.Decimal(18, 2)
  note          String?
  // Which supplier this line's cost price came from — picked per line since
  // a single export can cover products normally sourced from different
  // suppliers, unlike an import which is one delivery from one supplier.
  supplierId    String?
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])

  @@index([productId])
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  SHORT
  COMPLETED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(cuid())
  code        String           @unique
  warehouseId String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  orderDate   DateTime         @default(now())
  status      SalesOrderStatus @default(DRAFT)
  note        String?
  createdById String?
  createdBy   User?            @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())

  items       SalesOrderItem[]
  stockExport StockExport?
}

model SalesOrderItem {
  id               String     @id @default(cuid())
  salesOrderId     String
  salesOrder       SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product    @relation(fields: [productId], references: [id])
  quantity         Decimal    @db.Decimal(18, 3)
  // Receiving checklist: staff ticks each line once received in full; a
  // partially received line can log how much actually arrived instead.
  received         Boolean    @default(false)
  receivedQuantity Decimal?   @db.Decimal(18, 3)
}

enum InventoryCountStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model InventoryCount {
  id          String               @id @default(cuid())
  code        String               @unique
  warehouseId String
  warehouse   Warehouse            @relation(fields: [warehouseId], references: [id])
  countDate   DateTime
  status      InventoryCountStatus @default(DRAFT)
  note        String?
  createdById String?
  createdBy   User?                @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())

  items InventoryCountItem[]

  @@index([warehouseId, countDate])
}

model InventoryCountItem {
  id               String         @id @default(cuid())
  inventoryCountId String
  inventoryCount   InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  actualQuantity   Decimal        @db.Decimal(18, 3)
  note             String?

  @@unique([inventoryCountId, productId])
}

// Simple stock check for staff: just "what's on hand right now" per product,
// no warehouse and no system-vs-actual comparison (that's the separate,
// admin-only InventoryCount feature above). A permanent one-shot log entry —
// no draft/complete workflow, no editing after creation.
model StockCheck {
  id          String   @id @default(cuid())
  code        String   @unique
  note        String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  items         StockCheckItem[]
  finishedItems StockCheckFinishedItem[]
}

// Nguyên liệu line: tồn chẵn (theo đơn vị chính của hàng hoá) + tồn lẻ (luôn
// tính bằng gam), tách riêng vì đơn vị khác nhau.
model StockCheckItem {
  id            String     @id @default(cuid())
  stockCheckId  String
  stockCheck    StockCheck @relation(fields: [stockCheckId], references: [id], onDelete: Cascade)
  productId     String
  product       Product    @relation(fields: [productId], references: [id])
  wholeQuantity Decimal?   @db.Decimal(18, 3)
  looseQuantity Decimal?   @db.Decimal(18, 3)
  note          String?

  @@unique([stockCheckId, productId])
}

// Đồ thành phẩm line: danh sách độc lập với nguyên liệu (không phải mỗi
// nguyên liệu có 1 đồ thành phẩm tương ứng).
model StockCheckFinishedItem {
  id                 String           @id @default(cuid())
  stockCheckId       String
  stockCheck         StockCheck       @relation(fields: [stockCheckId], references: [id], onDelete: Cascade)
  finishedGoodItemId String
  finishedGoodItem   FinishedGoodItem @relation(fields: [finishedGoodItemId], references: [id])
  quantity           Decimal          @db.Decimal(18, 3)
  note               String?

  @@unique([stockCheckId, finishedGoodItemId])
}
