generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryCounts          InventoryCount[]
  salesOrders              SalesOrder[]
  reorderThresholds        ProductReorderThreshold[]
  stockChecks              StockCheck[]
  materialWastes           MaterialWaste[]
  costChecks               CostCheck[]               @relation("CostCheckShop")
  costChecksCreated        CostCheck[]               @relation("CostCheckCreatedBy")
  materialTransfersFrom    MaterialTransfer[]        @relation("MaterialTransferFrom")
  materialTransfersTo      MaterialTransfer[]        @relation("MaterialTransferTo")
  materialTransfersCreated MaterialTransfer[]        @relation("MaterialTransferCreatedBy")
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  createdAt DateTime @default(now())

  stockImports    StockImport[]
  stockExports    StockExport[]
  salesOrders     SalesOrder[]
  inventoryCounts InventoryCount[]
}

model ProductGroup {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  products Product[]
}

model Unit {
  id   String @id @default(cuid())
  code String @unique
  name String

  products             Product[]
  finishedGoodItems    FinishedGoodItem[]
  productsAsRecipeUnit Product[]          @relation("ProductRecipeUnit")
}

// Nhóm món cho Check Cost (doanh thu/chi phí tách theo nhóm) — để trống với món chưa phân loại.
enum FinishedGoodCategory {
  TRA
  DAV
  // Vật tư/đồ đã pha chế sẵn cần kiểm kê vật lý (ly, ống hút, nắp, nước pha sẵn...) —
  // khác với TRA/DAV vốn là món bán qua POS, chỉ dùng để tính doanh thu Check Cost.
  THANH_PHAM
}

// Catalog of "đồ thành phẩm" (prepared/finished items and supplies checked
// alongside raw materials in a phiếu kiểm kê) — independent of Product, since
// many of these (cups, straws, lids, brewed liquids) aren't raw-material SKUs.
model FinishedGoodItem {
  id           String                @id @default(cuid())
  code         String                @unique
  name         String
  unitId       String
  unit         Unit                  @relation(fields: [unitId], references: [id])
  category     FinishedGoodCategory?
  sellingPrice Decimal?              @db.Decimal(18, 2)
  createdAt    DateTime              @default(now())

  stockCheckFinishedItems    StockCheckFinishedItem[]
  materialWasteFinishedItems MaterialWasteFinishedItem[]
  // Công thức: nguyên liệu + định lượng cần để làm ra 1 đơn vị đồ thành phẩm/món này — dùng cho tính Check Cost.
  recipeItems                FinishedGoodRecipeItem[]
  costCheckSoldItems         CostCheckSoldItem[]
}

// Công thức (BOM): 1 đơn vị của 1 đồ thành phẩm/món cần bao nhiêu nguyên liệu — định lượng luôn tính theo
// Product.recipeUnit (vd Gram), không theo đơn vị chính của nguyên liệu (vd Hộp).
model FinishedGoodRecipeItem {
  id                 String           @id @default(cuid())
  finishedGoodItemId String
  finishedGoodItem   FinishedGoodItem @relation(fields: [finishedGoodItemId], references: [id], onDelete: Cascade)
  productId          String
  product            Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantityPerUnit    Decimal          @db.Decimal(18, 4)

  @@unique([finishedGoodItemId, productId])
}

// Loại hàng hoá — 5 giá trị cố định trong code, dùng để gộp chi phí cho Check Cost
// (NVL -> chi phí NVL Trà; COC_TAKE -> cốc & ống hút riêng; BANH -> chi phí ĐAV qua công thức
// 1 dòng; DUNG_CU/KHAC -> không tính vào Check Cost). Sửa được bình thường trên từng hàng hoá,
// chỉ 5 tên loại là cố định, không thêm loại mới qua giao diện.
enum ProductType {
  NVL
  COC_TAKE
  BANH
  DUNG_CU
  KHAC
}

model Product {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  unitId         String
  unit           Unit         @relation(fields: [unitId], references: [id])
  productGroupId String
  productGroup   ProductGroup @relation(fields: [productGroupId], references: [id])
  costPrice      Decimal      @default(0) @db.Decimal(18, 2)
  type           ProductType  @default(NVL)
  note           String?
  createdAt      DateTime     @default(now())

  // Quy đổi cho công thức/check cost: 1 [đơn vị chính] = recipeUnitsPerBaseUnit [recipeUnit, vd gam].
  // Để trống nếu công thức dùng thẳng đơn vị chính (hệ số quy đổi = 1).
  recipeUnitId           String?
  recipeUnit             Unit?    @relation("ProductRecipeUnit", fields: [recipeUnitId], references: [id])
  recipeUnitsPerBaseUnit Decimal? @db.Decimal(18, 4)

  stockImportItems      StockImportItem[]
  stockExportItems      StockExportItem[]
  inventoryCountItems   InventoryCountItem[]
  salesOrderItems       SalesOrderItem[]
  reorderThresholds     ProductReorderThreshold[]
  stockCheckItems       StockCheckItem[]
  supplierPrices        ProductSupplierPrice[]
  recipeLines           FinishedGoodRecipeItem[]
  materialWasteItems    MaterialWasteItem[]
  materialTransferItems MaterialTransferItem[]
}

// Per-supplier price list: the same product can be sourced from more than
// one supplier at different import/export prices. Optional — a product with
// no rows here just falls back to Product.costPrice everywhere.
model ProductSupplierPrice {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  importPrice Decimal  @db.Decimal(18, 2)
  exportPrice Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now())

  @@unique([productId, supplierId])
}

// Per-user reorder thresholds for "Order nhanh": each user has their own
// min/max per product (e.g. different counters/staff restock to different
// levels), so this is scoped by user, not a global Product setting.
model ProductReorderThreshold {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity Decimal  @db.Decimal(18, 3)
  maxQuantity Decimal  @db.Decimal(18, 3)
  createdAt   DateTime @default(now())

  @@unique([userId, productId])
}

model Supplier {
  id      String  @id @default(cuid())
  code    String  @unique
  name    String
  phone   String?
  address String?

  stockImports          StockImport[]
  stockExports          StockExport[]
  productPrices         ProductSupplierPrice[]
  stockExportItems      StockExportItem[]
  materialTransferItems MaterialTransferItem[]
}

model Customer {
  id      String  @id @default(cuid())
  code    String  @unique
  name    String
  phone   String?
  address String?

  stockImports StockImport[]
  stockExports StockExport[]
}

enum StockTransactionStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum StockImportType {
  PURCHASE
  CUSTOMER_RETURN
  TRANSFER_IN
  OTHER
}

enum StockExportType {
  SALE
  SUPPLIER_RETURN
  TRANSFER_OUT
  DAMAGE
  OTHER
}

enum TransactionForm {
  CASH
  BANK_TRANSFER
  DEBT
  OTHER
}

model StockImport {
  id            String                 @id @default(cuid())
  code          String                 @unique
  type          StockImportType        @default(PURCHASE)
  transactionAt DateTime
  form          TransactionForm        @default(CASH)
  status        StockTransactionStatus @default(COMPLETED)
  note          String?
  warehouseId   String
  warehouse     Warehouse              @relation(fields: [warehouseId], references: [id])
  supplierId    String?
  supplier      Supplier?              @relation(fields: [supplierId], references: [id])
  customerId    String?
  customer      Customer?              @relation(fields: [customerId], references: [id])
  createdById   String?
  createdAt     DateTime               @default(now())

  items StockImportItem[]

  @@index([warehouseId, transactionAt])
}

model StockImportItem {
  id            String      @id @default(cuid())
  stockImportId String
  stockImport   StockImport @relation(fields: [stockImportId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Decimal     @db.Decimal(18, 3)
  costPrice     Decimal     @db.Decimal(18, 2)
  costAmount    Decimal     @db.Decimal(18, 2)
  note          String?

  @@index([productId])
}

model StockExport {
  id            String                 @id @default(cuid())
  code          String                 @unique
  type          StockExportType        @default(SALE)
  transactionAt DateTime
  form          TransactionForm        @default(CASH)
  status        StockTransactionStatus @default(COMPLETED)
  note          String?
  warehouseId   String
  warehouse     Warehouse              @relation(fields: [warehouseId], references: [id])
  supplierId    String?
  supplier      Supplier?              @relation(fields: [supplierId], references: [id])
  customerId    String?
  customer      Customer?              @relation(fields: [customerId], references: [id])
  salesOrderId  String?                @unique
  salesOrder    SalesOrder?            @relation(fields: [salesOrderId], references: [id])
  createdById   String?
  createdAt     DateTime               @default(now())

  items StockExportItem[]

  @@index([warehouseId, transactionAt])
}

model StockExportItem {
  id            String      @id @default(cuid())
  stockExportId String
  stockExport   StockExport @relation(fields: [stockExportId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Decimal     @db.Decimal(18, 3)
  costPrice     Decimal     @db.Decimal(18, 2)
  costAmount    Decimal     @db.Decimal(18, 2)
  note          String?
  // Which supplier this line's cost price came from — picked per line since
  // a single export can cover products normally sourced from different
  // suppliers, unlike an import which is one delivery from one supplier.
  supplierId    String?
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])

  @@index([productId])
}

enum SalesOrderStatus {
  DRAFT
  PENDING_CONFIRM
  CONFIRMED
  SHORT
  COMPLETED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(cuid())
  code        String           @unique
  warehouseId String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  orderDate   DateTime         @default(now())
  status      SalesOrderStatus @default(DRAFT)
  note        String?
  createdById String?
  createdBy   User?            @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  // Lúc completeSalesOrderReceiving chạy xong gần nhất (dù ra SHORT hay COMPLETED) — dùng để lọc
  // "nhận trong kỳ" theo mốc thời gian thực tế nhận hàng, thay vì orderDate (lúc đặt).
  completedAt DateTime?

  items       SalesOrderItem[]
  stockExport StockExport?
}

model SalesOrderItem {
  id               String     @id @default(cuid())
  salesOrderId     String
  salesOrder       SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product    @relation(fields: [productId], references: [id])
  quantity         Decimal    @db.Decimal(18, 3)
  // Receiving checklist: staff ticks each line once received in full; a
  // partially received line can log how much actually arrived instead.
  received         Boolean    @default(false)
  receivedQuantity Decimal?   @db.Decimal(18, 3)
  // Lý do admin đổi số lượng lúc xác nhận đơn — hiển thị lại cho nhân viên xem khi đơn ở
  // trạng thái chờ xác nhận (PENDING_CONFIRM).
  note             String?
}

enum InventoryCountStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model InventoryCount {
  id          String               @id @default(cuid())
  code        String               @unique
  warehouseId String
  warehouse   Warehouse            @relation(fields: [warehouseId], references: [id])
  countDate   DateTime
  status      InventoryCountStatus @default(DRAFT)
  note        String?
  createdById String?
  createdBy   User?                @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())

  items InventoryCountItem[]

  @@index([warehouseId, countDate])
}

model InventoryCountItem {
  id               String         @id @default(cuid())
  inventoryCountId String
  inventoryCount   InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  actualQuantity   Decimal        @db.Decimal(18, 3)
  note             String?

  @@unique([inventoryCountId, productId])
}

// Simple stock check for staff: just "what's on hand right now" per product,
// no warehouse and no system-vs-actual comparison (that's the separate,
// admin-only InventoryCount feature above). A permanent one-shot log entry —
// no draft/complete workflow, no editing after creation.
model StockCheck {
  id          String   @id @default(cuid())
  code        String   @unique
  note        String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  // Thời điểm kiểm thực tế do người dùng chọn (mặc định lúc lưu) — dùng làm mốc kỳ Check Cost,
  // khác với createdAt (lúc bản ghi được lưu vào hệ thống).
  checkedAt   DateTime @default(now())

  items               StockCheckItem[]
  finishedItems       StockCheckFinishedItem[]
  costChecksAsOpening CostCheck[]              @relation("CostCheckOpening")
  costChecksAsClosing CostCheck[]              @relation("CostCheckClosing")
}

// Nguyên liệu line: tồn chẵn (theo đơn vị chính của hàng hoá) + tồn lẻ (luôn
// tính bằng gam), tách riêng vì đơn vị khác nhau.
model StockCheckItem {
  id            String     @id @default(cuid())
  stockCheckId  String
  stockCheck    StockCheck @relation(fields: [stockCheckId], references: [id], onDelete: Cascade)
  productId     String
  product       Product    @relation(fields: [productId], references: [id])
  wholeQuantity Decimal?   @db.Decimal(18, 3)
  looseQuantity Decimal?   @db.Decimal(18, 3)
  note          String?

  @@unique([stockCheckId, productId])
}

// Đồ thành phẩm line: danh sách độc lập với nguyên liệu (không phải mỗi
// nguyên liệu có 1 đồ thành phẩm tương ứng).
model StockCheckFinishedItem {
  id                 String           @id @default(cuid())
  stockCheckId       String
  stockCheck         StockCheck       @relation(fields: [stockCheckId], references: [id], onDelete: Cascade)
  finishedGoodItemId String
  finishedGoodItem   FinishedGoodItem @relation(fields: [finishedGoodItemId], references: [id])
  quantity           Decimal          @db.Decimal(18, 3)
  note               String?

  @@unique([stockCheckId, finishedGoodItemId])
}

// Phiếu huỷ nguyên liệu tại quán (nguyên liệu hỏng/đổ bỏ) — cùng kiểu tự phục vụ như
// StockCheck: userId chính là quán (người tạo), không sửa được sau khi tạo.
model MaterialWaste {
  id          String   @id @default(cuid())
  code        String   @unique
  note        String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  // Thời điểm huỷ thực tế do người dùng chọn (mặc định lúc lưu) — dùng làm mốc lọc kỳ Check Cost,
  // khác với createdAt (lúc bản ghi được lưu vào hệ thống).
  wasteAt     DateTime @default(now())

  items         MaterialWasteItem[]
  finishedItems MaterialWasteFinishedItem[]
}

model MaterialWasteItem {
  id              String        @id @default(cuid())
  materialWasteId String
  materialWaste   MaterialWaste @relation(fields: [materialWasteId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  wholeQuantity   Decimal?      @db.Decimal(18, 3)
  looseQuantity   Decimal?      @db.Decimal(18, 3)
  note            String?

  @@index([productId])
}

// Đồ thành phẩm huỷ — cùng cấu trúc StockCheckFinishedItem (1 số lượng duy nhất, không tách chẵn/lẻ).
model MaterialWasteFinishedItem {
  id                 String           @id @default(cuid())
  materialWasteId    String
  materialWaste      MaterialWaste    @relation(fields: [materialWasteId], references: [id], onDelete: Cascade)
  finishedGoodItemId String
  finishedGoodItem   FinishedGoodItem @relation(fields: [finishedGoodItemId], references: [id])
  quantity           Decimal          @db.Decimal(18, 3)
  note               String?

  @@unique([materialWasteId, finishedGoodItemId])
}

// Phiếu Check Cost: đối soát nguyên liệu tiêu hao thực tế (giữa 2 phiếu kiểm kê quán)
// so với tiêu hao theo công thức (từ SL đồ thành phẩm/món đã bán trong kỳ). userId là
// quán được đối soát — khác với createdById vì admin nhập hộ dữ liệu bán hàng cho quán.
model CostCheck {
  id                  String     @id @default(cuid())
  code                String     @unique
  userId              String
  user                User       @relation("CostCheckShop", fields: [userId], references: [id])
  openingStockCheckId String
  openingStockCheck   StockCheck @relation("CostCheckOpening", fields: [openingStockCheckId], references: [id])
  closingStockCheckId String
  closingStockCheck   StockCheck @relation("CostCheckClosing", fields: [closingStockCheckId], references: [id])
  note                String?
  // Khuyến mãi/giảm giá trong kỳ, nhập tay theo nhóm — dùng tính doanh thu thuần.
  discountTra         Decimal?   @db.Decimal(18, 2)
  discountDav         Decimal?   @db.Decimal(18, 2)
  createdById         String?
  createdBy           User?      @relation("CostCheckCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime   @default(now())
  // Chốt cứng { rows, summary } ngay khi tạo phiếu — sửa giá vốn/giá bán/công thức
  // sau này không được phép làm thay đổi số liệu của phiếu đã tạo.
  reportSnapshot      Json?

  soldItems CostCheckSoldItem[]
}

model CostCheckSoldItem {
  id                 String           @id @default(cuid())
  costCheckId        String
  costCheck          CostCheck        @relation(fields: [costCheckId], references: [id], onDelete: Cascade)
  finishedGoodItemId String
  finishedGoodItem   FinishedGoodItem @relation(fields: [finishedGoodItemId], references: [id])
  quantitySold       Decimal          @db.Decimal(18, 3)

  @@unique([costCheckId, finishedGoodItemId])
}

// Điều chuyển nguyên liệu giữa 2 quán (không qua kho trung tâm) — admin tạo hộ, không có bước
// quán nhận xác nhận lại (tin theo đúng số admin ghi). Ảnh hưởng công thức Check Cost: trừ vào
// quán gửi, cộng vào quán nhận, giống hệt cách "Nhận trong kỳ"/"Đã huỷ" đang được cộng/trừ.
model MaterialTransfer {
  id          String   @id @default(cuid())
  code        String   @unique
  fromUserId  String
  fromUser    User     @relation("MaterialTransferFrom", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      User     @relation("MaterialTransferTo", fields: [toUserId], references: [id])
  transferAt  DateTime @default(now())
  note        String?
  createdById String?
  createdBy   User?    @relation("MaterialTransferCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  items MaterialTransferItem[]
}

model MaterialTransferItem {
  id                 String           @id @default(cuid())
  materialTransferId String
  materialTransfer   MaterialTransfer @relation(fields: [materialTransferId], references: [id], onDelete: Cascade)
  productId          String
  product            Product          @relation(fields: [productId], references: [id])
  wholeQuantity      Decimal?         @db.Decimal(18, 3)
  looseQuantity      Decimal?         @db.Decimal(18, 3)
  // Nguồn giá vốn (để sau này tính doanh thu/chỉ số khác cho Check Cost) — không bắt buộc.
  supplierId         String?
  supplier           Supplier?        @relation(fields: [supplierId], references: [id])
  costPrice          Decimal?         @db.Decimal(18, 2)
  note               String?

  @@index([productId])
}
